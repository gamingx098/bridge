      "source": [
        "# Basic forward fill approach to handle data gaps (EE-inspired interpolation)\n",
        "def apply_forward_fill(data, method='linear'):\n",
        "    \"\"\"\n",
        "    Apply forward-fill for handling missing data gaps\n",
        "    \"\"\"\n",
        "    filled_data = data.fillna(method='forward')\n",
        "    return filled_data"
      ]
